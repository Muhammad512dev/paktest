# Required
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
CORS_ORIGIN="https://your-frontend.pages.dev"

# Gemini AI - server only. Never use VITE_ for this value.
GEMINI_API_KEY="your-gemini-api-key"

# Upload storage: choose exactly one: local, supabase, or r2.
# Local is best only for your computer or a server with a persistent disk.
STORAGE_PROVIDER="r2"

# Cloudflare R2 (recommended for hosted images/files)
# Create an S3 API token in Cloudflare R2 and use its Access Key ID and Secret.
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="examforge-uploads"
# Public custom domain or r2.dev URL for the bucket. Do not use the S3 endpoint here.
R2_PUBLIC_URL="https://files.your-domain.com"

# Supabase Storage (used only when STORAGE_PROVIDER=supabase)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="examforge-uploads"

# Required only if STORAGE_PROVIDER=local and frontend/backend have separate domains.
PUBLIC_API_URL="https://your-backend.onrender.com"
